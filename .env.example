# Anthropic API key — required for AI post generation
ANTHROPIC_API_KEY=

# Vercel deployment secrets (CI/CD only — configure in GitHub repository settings)
# Get these from the Vercel dashboard or `vercel env pull`
# VERCEL_TOKEN=         # Personal access token from vercel.com/account/tokens
# VERCEL_ORG_ID=        # Team/user ID from vercel.com/account
# VERCEL_PROJECT_ID=    # Project ID from vercel.com/<team>/<project>/settings
