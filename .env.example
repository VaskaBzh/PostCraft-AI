# ============================================================
# REQUIRED: Add these in Vercel Dashboard or via CLI
# ============================================================

# 1. Anthropic API key (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# 2. Upstash Redis — required for rate limiting (console.upstash.com -> Create DB -> REST API)
#    Without these, rate limiting is DISABLED in production (security risk)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 3. Allowed origins (your production domain, comma-separated)
#    Leave empty to auto-detect from VERCEL_URL
ALLOWED_ORIGINS=

# ============================================================
# HOW TO ADD TO VERCEL PRODUCTION
# ============================================================
# Option A — Vercel Dashboard:
#   vercel.com -> project "post-craft" -> Settings -> Environment Variables -> Add
#   Select "Production" (and optionally "Preview") for each variable.
#
# Option B — Vercel CLI:
#   npm i -g vercel
#   vercel login
#   vercel env add ANTHROPIC_API_KEY production
#   vercel env add UPSTASH_REDIS_REST_URL production
#   vercel env add UPSTASH_REDIS_REST_TOKEN production
#   vercel env add ALLOWED_ORIGINS production
#
# Verify locally after adding:
#   vercel env pull .env.local
#
# Rate limiting activates automatically when Upstash vars are present.
# To verify in production: POST 11 times to /api/generate — 12th should return 429.

# ============================================================
# AUTO-SET BY VERCEL (do not add manually)
# ============================================================
# VERCEL_URL                      — URL of the current deployment
# VERCEL_PROJECT_PRODUCTION_URL   — URL of production deployment

# ============================================================
# CI/CD (GitHub repository secrets, not .env)
# ============================================================
# VERCEL_TOKEN=       # vercel.com/account/tokens
# VERCEL_ORG_ID=      # vercel.com/account
# VERCEL_PROJECT_ID=  # vercel.com/<team>/<project>/settings
